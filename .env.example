# =============================================================================
# OneTable — Environment Variables Template
# =============================================================================
# Auto-provisioned by Vercel + Neon integration. To populate .env.local:
#   vercel env pull .env.local
# .env.local is gitignored. Never commit it. (block-env-writes hook also blocks.)
# To add a new variable: `vercel env add VAR_NAME` then re-pull.
# =============================================================================

# Database (Neon Postgres via Vercel Storage — auto-managed)
DATABASE_URL=
DATABASE_URL_UNPOOLED=
# Marker del guard de entorno (lib/db-guard.ts). Obligatorio para correr
# tests/seed/reset locales contra la branch development de Neon.
ONETABLE_DB_ENV="development"

# Vercel + Neon also provisions: POSTGRES_*, PG*, NEON_PROJECT_ID.
# Not used directly with Prisma, but kept by `vercel env pull`.

# NextAuth v5
# AUTH_SECRET: generate with `openssl rand -base64 32`
# AUTH_URL: prod=https://onetable.vercel.app, preview=https://$VERCEL_URL, dev=http://localhost:3000
AUTH_SECRET=
AUTH_URL=

# Demo seed (Phase 1 — ANTAD demo)
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=
